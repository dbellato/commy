
# After running `azd up`, the following can be found in `.azure/<env name>/.env`
# Azure AI Search endpoint and index name can be found in Azure Portal.  See https://learn.microsoft.com/en-us/azure/ai-services/agents/how-to/tools/azure-ai-search?tabs=azurecli%2Cpython&pivots=overview-azure-ai-search
AZURE_AIPROJECT_CONNECTION_STRING="" 
AZURE_AI_CHAT_DEPLOYMENT_NAME="gpt-4o"
AZURE_AI_EMBED_DEPLOYMENT_NAME="text-embedding-3-small"
AZURE_AI_EMBED_DIMENSIONS=1536 
AZURE_EXISTING_AIPROJECT_ENDPOINT="https://digiaifoundry.services.ai.azure.com/api/projects/commy"
AZURE_EXISTING_AIPROJECT_API_KEY=AZURE_EXISTING_AIPROJECT_API_KEY_HERE
AZURE_AI_SEARCH_ENDPOINT="https://digisearch.search.windows.net" 
AZURE_AI_SEARCH_API_KEY=AZURE_AI_SEARCH_API_KEY_HERE
AZURE_AI_SEARCH_INDEX_NAME="rag-manuals-v2" 
AZURE_AI_SEARCH_INDEX_NAME_SPECS="rag-specs" 
DB-SERVER="comacchio-az-sql-server.database.windows.net" 
DB-NAME="commy-db" 
DB-USER=DB-USER_HERE
DB-PASSWORD=DB-PASSWORD_HERE
# Local development only: bypasses Azure Easy Auth header
DEV_USER_EMAIL=your.email@domain.com


